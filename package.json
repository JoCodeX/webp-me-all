{
  "name": "webp-me-all",
  "version": "1.0.0",
  "description": "Convert all your images to WebP and automatically update every reference in your codebase (TS, TSX, JSX, JSON, MD, HTML, CSS). The missing migration tool.",
  "keywords": [
    "webp",
    "image",
    "convert",
    "converter",
    "optimize",
    "performance",
    "image-optimization",
    "webp-converter",
    "migration",
    "codebase-migration",
    "refactor",
    "cli",
    "sharp",
    "png",
    "jpg",
    "jpeg",
    "gif",
    "tiff",
    "avif",
    "next",
    "astro",
    "vite",
    "remix",
    "react",
    "vue",
    "svelte",
    "nuxt",
    "sveltekit"
  ],
  "sideEffects": false,
  "homepage": "https://github.com/JoCodeX/webp-me-all#readme",
  "bugs": {
    "url": "https://github.com/JoCodeX/webp-me-all/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JoCodeX/webp-me-all.git"
  },
  "license": "MIT",
  "author": {
    "name": "Jose",
    "email": "info@xerberuz.com"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "webp-me-all": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "release": "semantic-release"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "kleur": "^4.1.5",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^22.9.0",
    "@vitest/coverage-v8": "^2.1.5",
    "semantic-release": "^24.2.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
